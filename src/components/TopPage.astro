---
import Layout from "../layouts/Layout.astro";
import type { AstroComponentFactory } from "astro/runtime/server/index.js";
import { Image } from "astro:assets";
import finger4 from "../assets/finger4.jpg";

interface Props {
	locale?: "ja" | "en";
	ContentComponent?: AstroComponentFactory;
	frontmatter?: any;
}

const { locale = "ja", ContentComponent, frontmatter } = Astro.props;

const isEnglish = locale === "en";

const title =
	frontmatter?.title ??
	(isEnglish
		? "Materialized Graphics Project"
		: "実体化映像による多次元インタラクション");
const description =
	frontmatter?.description ?? "JST CREST Materialized Graphics Project";
---

<Layout
	title={title}
	description={description}
	currentPath={isEnglish ? "/en/" : "/"}
	locale={locale}
	languageSwitchHref={isEnglish ? "/" : "/en/"}
>
	<section class="top-hero">
		<div class="top-hero__media">
			<Image
				src={finger4}
				alt="Finger touching a materialized graphic"
				loading="eager"
			/>
		</div>
		<div class="container top-hero__body">
			<h1>Materialized Graphics</h1>
			<p class="top-hero__tagline">Graphics with a Physical Entity</p>
		</div>
	</section>

	<main class="container top-page">
		<div class="surface prose top-page__content">
			{ContentComponent && <ContentComponent />}
		</div>
	</main>
</Layout>

<style>
	.top-hero {
		position: relative;
		height: 35vh;
		min-height: 150px;
		display: flex;
		align-items: center;
		justify-content: center;
		color: #fff;
		text-align: center;
		overflow: hidden;
		background-color: #000;
	}

	.top-hero__media {
		position: absolute;
		inset: 0;
		opacity: 0.7;
	}

	.top-hero__media :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.top-hero__body {
		position: relative;
		z-index: 1;
		text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
	}

	.top-hero h1 {
		margin: 0;
		font-size: clamp(1.2rem, 4vw, 2.5rem);
		line-height: 1.1;
		font-weight: 800;
		color: #ffffff;
	}

	.top-hero__tagline {
		margin: 0.5rem 0 0;
		font-size: clamp(0.6rem, 1.5vw, 1.1rem);
		font-weight: 600;
	}

	.top-page {
		padding-top: 3rem;
		padding-bottom: 4rem;
	}

	.top-page__content {
		padding: 2.5rem;
		max-width: none;
		box-shadow: none;
		border: none;
	}

	/* MDX content styles */
	:global(.prose img) {
		border: none !important;
		box-shadow: none !important;
	}

	:global(.pillar-grid) {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
		margin: 3rem 0;
	}

	:global(.pillar-item) {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
	}

	:global(.pillar-label) {
		font-size: 1.5rem;
		font-weight: 700;
		color: #007cba;
		margin-bottom: 1rem;
		text-align: center;
	}

	:global(.pillar-item img) {
		width: 100%;
		aspect-ratio: 4 / 3;
		object-fit: contain;
		border: none;
	}

	:global(.video-wrapper) {
		position: relative;
		padding-bottom: 56.25%;
		height: 0;
		overflow: hidden;
		margin: 1rem 0;
	}

	:global(.video-wrapper iframe) {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
	}

	:global(.footer-mark) {
		margin-top: 4rem;
		text-align: center;
	}

	:global(.footer-mark img) {
		max-width: 500px;
		width: 100%;
		height: auto;
		border: none;
	}

	@media (max-width: 900px) {
		:global(.pillar-grid) {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 640px) {
		.top-hero {
			height: 30vh;
			min-height: 200px;
		}

		.top-page__content {
			padding: 1.5rem;
		}
	}
</style>
