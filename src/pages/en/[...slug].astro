---
import type { AstroComponentFactory } from "astro/runtime/server/index.js";
import StaticPageRenderer from "../../components/StaticPageRenderer.astro";
import {
	englishStaticPageEntries,
	type StaticPageEntry,
} from "../../data/page-registry";
import { loadLocalizedContent, type FrontmatterLike } from "../../lib/content";

type MarkdownModule = {
	default: AstroComponentFactory;
	frontmatter?: FrontmatterLike;
};

type RouteProps = { type: "static"; entry: StaticPageEntry };

const pageModules = import.meta.glob("../../content/pages/*.md") as Record<
	string,
	() => Promise<MarkdownModule>
>;
const pageHtmlModules = import.meta.glob("../../content/pages/*.html", {
	query: "?raw",
	import: "default",
}) as Record<string, () => Promise<string>>;

export function getStaticPaths() {
	return [
		...englishStaticPageEntries.map((entry) => ({
			params: { slug: entry.slug },
			props: { type: "static", entry },
		})),
	];
}

const { type, entry } = Astro.props as RouteProps;

let ContentComponent;
let frontmatter;
let htmlContent = "";
let fallbackNotice;
let sourceType: "markdown" | "html" = "markdown";

if (type === "static" && entry.contentId) {
	const content = await loadLocalizedContent({
		locale: "en",
		basePath: `../../content/pages/${entry.contentId}`,
		markdownModules: pageModules,
		htmlModules: pageHtmlModules,
	});
	ContentComponent = content.ContentComponent;
	frontmatter = content.frontmatter;
	htmlContent = content.htmlContent;
	fallbackNotice = content.isFallback
		? "This page is not yet available in English. 日本語版の内容を表示しています。"
		: undefined;
}
---

<StaticPageRenderer
	currentPath={entry.currentPath}
	locale="en"
	frontmatter={frontmatter}
	ContentComponent={ContentComponent}
	htmlContent={htmlContent}
	title={entry.title}
	description={entry.description}
	lead={entry.lead}
	introHtml={entry.introHtml}
	fallbackNotice={fallbackNotice}
	kind={entry.kind}
/>
