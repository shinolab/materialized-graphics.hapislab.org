---
import { Image } from "astro:assets";
import crestLogo from "../assets/Logos_crest_jst.png";
import { getPrimaryNav } from "../data/navigation";
import { siteMeta } from "../data/site";
import { withBasePath } from "../lib/urls";

interface Props {
    locale?: "ja" | "en";
}

const { locale = "ja" } = Astro.props;
const footerNav = getPrimaryNav(locale).filter(
    (item) => item.href !== (locale === "en" ? "/en/" : "/"),
);
---

<footer class="site-footer">
    <div class="container site-footer__inner">
        <div class="site-footer__crest-logo">
            <Image src={crestLogo} alt="JST CREST" />
        </div>
        <p class="site-footer__meta">
            © {
                locale === "en"
                    ? siteMeta.englishName
                    : `${siteMeta.englishName}`
            }
        </p>
    </div>
</footer>

<style>
    .site-footer {
        margin-top: auto;
        padding: 3rem 0 2.5rem;
    }

    .site-footer__inner {
        text-align: center;
    }

    .site-footer__crest-logo {
        margin-bottom: 2rem;
        display: flex;
        justify-content: center;
    }

    .site-footer__crest-logo :global(img) {
        max-width: 400px;
        width: 100%;
        height: auto;
        display: block;
    }

    .site-footer__nav {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 0.8rem;
        margin-bottom: 1rem;
    }

    .site-footer__nav a {
        color: var(--text);
        text-decoration: none;
    }

    .site-footer__nav a:not(:last-child)::after {
        content: "|";
        margin-left: 0.8rem;
        color: var(--text-subtle);
    }

    .site-footer__meta {
        margin: 0.2rem 0;
        color: var(--text-subtle);
    }
</style>
