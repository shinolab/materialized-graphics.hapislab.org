---
import { Image } from "astro:assets";
import { getPrimaryNav } from "../data/navigation";
import { siteMeta } from "../data/site";
import { withBase, withBasePath } from "../lib/urls";
import logoImg from "../assets/shinolab_logo.svg";

interface Props {
    currentPath?: string;
    locale?: "ja" | "en";
    languageSwitchHref?: string;
}

const { currentPath = "/", locale = "ja", languageSwitchHref } = Astro.props;

const navItems = getPrimaryNav(locale);
const homePath = navItems[0]?.href ?? "/";
const homeHref = withBase(homePath) ?? homePath;
const topbarMeta =
    locale === "en"
        ? "The University of Tokyo"
        : "東京大学 新領域・情報理工・工学部";

const normalizePath = (path: string) => {
    if (path !== "/" && path.endsWith("/")) {
        return path.slice(0, -1);
    }

    return path;
};

const getDefaultLanguageSwitchHref = () => {
    const normalizedCurrentPath = normalizePath(currentPath);
    if (locale === "ja") {
        return (
            "/en" + (normalizedCurrentPath === "/" ? "" : normalizedCurrentPath)
        );
    }

    return normalizedCurrentPath.replace(/^\/en/, "") || "/";
};

const languageSwitch = {
    href:
        withBasePath(languageSwitchHref ?? getDefaultLanguageSwitchHref()) ??
        languageSwitchHref ??
        getDefaultLanguageSwitchHref(),
    label: locale === "en" ? "日本語" : "English",
};

const isActive = (href: string) => {
    const normalizedCurrentPath = normalizePath(currentPath);
    const normalizedHref = normalizePath(href);
    const normalizedHomeHref = normalizePath(homePath);

    if (normalizedHref === normalizedHomeHref) {
        return normalizedCurrentPath === normalizedHomeHref;
    }

    return (
        normalizedCurrentPath === normalizedHref ||
        normalizedCurrentPath.startsWith(`${normalizedHref}/`)
    );
};
---

<div class="site-topbar">
    <div class="container site-topbar__inner">
        <div class="site-topbar__meta-container">
            <span class="site-topbar__text-bundle">
                {topbarMeta}
            </span>
        </div>
    </div>
</div>

<header class="site-header">
    <div class="container site-header__inner">
        <a class="site-brand" href={homeHref}>
            <Image
                src={logoImg}
                alt="Shinoda & Makino Lab Logo"
                class="custom-mobile-logo-img"
                width={48}
                height={48}
                loading="eager"
            />
            <span class="site-brand__name">
                {locale === "en" ? siteMeta.englishName : siteMeta.japaneseName}
            </span>
        </a>
        <button
            type="button"
            class="custom-mobile-menu-btn"
            id="menu-trigger"
            aria-label="Menu"
        >
            <span></span>
        </button>

        <nav
            class="site-nav"
            aria-label={locale === "en" ? "Primary navigation" : "主要メニュー"}
        >
            {
                navItems.map((item) => (
                    <a
                        class:list={[
                            "site-nav__link",
                            { "site-nav__link--active": isActive(item.href) },
                        ]}
                        href={withBase(item.href)}
                    >
                        {item.label}
                    </a>
                ))
            }
            <a
                class="site-nav__link site-nav__link--language"
                href={languageSwitch.href}
            >
                <span aria-hidden="true">{locale === "en" ? "🇯🇵" : "🇺🇸"}</span>
                {languageSwitch.label}
            </a>
        </nav>
    </div>
</header>

<style>
    .site-topbar {
        background: var(--primary);
        color: #fff;
        padding: 0.3rem 0;
    }

    .site-topbar__inner {
        display: flex;
        justify-content: space-between;
        gap: 0.75rem;
    }

    .site-topbar__text-bundle {
        font-size: 1.1rem;
        line-height: 1;
    }

    .site-header {
        position: sticky;
        top: 0;
        z-index: 100;
        background: var(--surface);
        border-bottom: 1px solid var(--border);
        box-shadow: 0 0.35rem 1.5rem rgba(35, 35, 35, 0.08);
    }

    .site-header__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.2rem;
        padding-top: 1rem;
        padding-bottom: 0.8rem;
        position: relative;
    }

    .site-brand {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        gap: 15px;
        color: inherit;
        text-decoration: none;
    }

    .custom-mobile-logo-img {
        height: 3.3rem;
        width: auto;
        display: inline-block;
        vertical-align: middle;
        margin-top: -5px;
    }

    .site-brand__name {
        font-size: 1.8rem;
        font-weight: 700;
        line-height: 1.2;
        letter-spacing: 0;
        white-space: nowrap;
    }

    .site-nav {
        display: flex;
        flex-wrap: nowrap;
        justify-content: flex-end;
        gap: 1.5rem;
        width: 100%;
        margin-left: auto;
    }

    .site-nav__link {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.2rem 0;
        color: var(--text);
        font-size: 0.95rem;
        font-weight: 500;
        text-decoration: none;
        white-space: nowrap;
        transition: color 0.3s ease;
    }

    .site-nav__link::after {
        content: "";
        position: absolute;
        left: 0;
        bottom: 0;
        width: 0;
        height: 2px;
        background-color: var(--accent);
        transition: width 0.3s ease;
    }

    .site-nav__link:hover,
    .site-nav__link--active {
        color: var(--accent);
    }

    .site-nav__link:hover::after,
    .site-nav__link--active::after {
        width: 100%;
    }

    .site-nav__link--language {
        margin-left: 0.5rem;
    }

    .custom-mobile-menu-btn {
        display: none;
        width: 38px;
        height: 38px;
        border: 0;
        border-radius: 4px;
        background: var(--primary);
        color: #fff;
        position: relative;
        justify-content: center;
        align-items: center;
        cursor: pointer;
        flex-shrink: 0;
    }

    .custom-mobile-menu-btn span,
    .custom-mobile-menu-btn span::before,
    .custom-mobile-menu-btn span::after {
        display: block;
        position: absolute;
        width: 20px;
        height: 2px;
        background: currentColor;
        transition:
            transform 0.3s ease,
            opacity 0.3s ease,
            background 0.3s ease;
        content: "";
    }

    .custom-mobile-menu-btn span {
        position: relative;
    }

    .custom-mobile-menu-btn span::before {
        transform: translateY(-6px);
    }

    .custom-mobile-menu-btn span::after {
        transform: translateY(6px);
    }

    .site-header--menu-open .custom-mobile-menu-btn span {
        background: transparent;
    }

    .site-header--menu-open .custom-mobile-menu-btn span::before {
        transform: rotate(45deg);
    }

    .site-header--menu-open .custom-mobile-menu-btn span::after {
        transform: rotate(-45deg);
    }

    @media (max-width: 1024px) {
        .site-topbar__inner {
            flex-direction: column;
            align-items: start;
        }

        .site-header__inner {
            min-height: 70px;
            padding-top: 0.8rem;
            padding-bottom: 0.6rem;
        }

        .site-brand {
            flex: 1;
        }

        .site-brand__name {
            font-size: 1.1rem;
        }

        .custom-mobile-menu-btn {
            display: flex;
        }

        .site-nav {
            display: none;
        }

        .site-header--menu-open .site-nav {
            display: flex;
            flex-direction: column;
            position: absolute;
            top: 100%;
            left: 0;
            width: 100%;
            padding: 0.3rem 0 2.5rem;
            background: #fff;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
            z-index: 1000;
            max-height: calc(100vh - 120px);
            overflow-y: auto;
            -webkit-overflow-scrolling: touch;
        }

        .site-nav__link {
            display: block;
            padding: 0.5rem 1.25rem;
            border-bottom: 1px solid #f0f0f0;
            font-size: 1rem;
            line-height: 1.2;
        }

        .site-nav__link--language {
            margin-left: 0;
        }
    }

    @media (max-width: 570px) {
        :global(html:not([lang="ja"])) .site-brand__name {
            white-space: normal;
            word-break: break-word;
            max-width: 95%;
            line-height: 1.2;
            font-size: 1.4rem;
        }

        :global(html[lang="ja"]) .site-brand__name {
            font-size: 1.4rem;
        }

        .custom-mobile-logo-img {
            height: 2.64rem;
        }
    }
</style>

<script is:inline>
    (function () {
        function setupMenu() {
            const trigger = document.getElementById("menu-trigger");
            const header = document.querySelector(".site-header");
            if (trigger && header) {
                trigger.onclick = null;
                trigger.onclick = () => {
                    header.classList.toggle("site-header--menu-open");
                };
            }
        }
        setupMenu();
        document.addEventListener("astro:page-load", setupMenu);
    })();
</script>
