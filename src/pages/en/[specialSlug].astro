---
import DetailPageRenderer from "../../components/DetailPageRenderer.astro";
import {
	getSpecialPageSlugs,
	loadSpecialPageContent,
} from "../../lib/special-page-content";

export function getStaticPaths() {
	return getSpecialPageSlugs("en").map((specialSlug) => ({
		params: { specialSlug },
		props: { specialSlug },
	}));
}

const { specialSlug } = Astro.props;
const content = await loadSpecialPageContent("en", specialSlug);

const title = content.frontmatter?.title ?? specialSlug;
const description = content.frontmatter?.description;
const lead = content.frontmatter?.lead;
---

<DetailPageRenderer
	title={title}
	description={description}
	lead={lead}
	currentPath={`/en/${specialSlug}`}
	locale="en"
	ContentComponent={content.ContentComponent}
	htmlContent={content.htmlContent}
	fallbackNotice={content.isFallback
		? "This page is not yet available in English. 日本語版の内容を表示しています。"
		: undefined}
	languageSwitchHref={`/${specialSlug}`}
/>
