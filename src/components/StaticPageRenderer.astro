---
import type { AstroComponentFactory } from "astro/runtime/server/index.js";
import PageFrame from "./PageFrame.astro";

interface FrontmatterLike {
	title?: string;
	description?: string;
	lead?: string;
}

interface Props {
	locale?: "ja" | "en";
	currentPath: string;
	frontmatter?: FrontmatterLike;
	ContentComponent?: AstroComponentFactory;
	htmlContent?: string;
	title?: string;
	description?: string;
	lead?: string;
	fallbackNotice?: string;
	languageSwitchHref?: string;
}

const {
	locale = "ja",
	currentPath,
	frontmatter,
	ContentComponent,
	htmlContent = "",
	title,
	description,
	lead,
	fallbackNotice,
	languageSwitchHref,
} = Astro.props;

const pageTitle = title ?? frontmatter?.title ?? "";
const pageDescription = description ?? frontmatter?.description ?? "";
const pageLead = lead ?? frontmatter?.lead;
const shouldRenderContent = ContentComponent || htmlContent;
---

<PageFrame
	title={pageTitle}
	description={pageDescription}
	lead={pageLead}
	currentPath={currentPath}
	locale={locale}
	languageSwitchHref={languageSwitchHref}
>
	<div class="content-stack">
		{
			fallbackNotice && (
				<aside class="surface notice-card" role="note">
					<p>{fallbackNotice}</p>
				</aside>
			)
		}
		{
			shouldRenderContent && (
				<article class="surface prose">
					{ContentComponent && <ContentComponent />}
					{!ContentComponent && htmlContent && <Fragment set:html={htmlContent} />}
				</article>
			)
		}
	</div>
</PageFrame>

<style>
	:global(.member-grid) {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
		margin-top: 2rem;
	}

	:global(.member-card) {
		display: flex;
		flex-direction: column;
	}

	:global(.member-card h3) {
		color: #007cba;
		font-size: 1.1rem;
		margin-top: 0 !important;
		margin-bottom: 1rem !important;
		text-align: center;
		border-bottom: none !important;
	}

	:global(.member-card h3 a) {
		color: inherit !important;
		text-decoration: none !important;
	}

	:global(.member-card h3::before) {
		display: none !important;
	}

	:global(.member-card img) {
		width: 100%;
		max-width: 240px;
		height: 160px;
		object-fit: contain;
		margin: 0 auto 1rem !important;
		border: none !important;
		box-shadow: none !important;
		display: block;
	}

	:global(.member-card ul) {
		list-style: none;
		padding-left: 0 !important;
		margin: 0;
		text-align: center;
	}

	:global(.member-card li) {
		margin-bottom: 0 !important;
		line-height: 1.4;
		text-align: center;
		font-size: 0.95rem;
	}

	@media (max-width: 1024px) {
		:global(.member-grid) {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 768px) {
		:global(.member-grid) {
			grid-template-columns: 1fr;
			gap: 2.5rem;
		}

		:global(.member-card img) {
			width: 200px;
			height: auto;
			max-height: 150px;
		}
	}
</style>
