---
import type { AstroComponentFactory } from "astro/runtime/server/index.js";
import ResearchTopicArticle from "../../../components/ResearchTopicArticle.astro";
import { loadLocalizedContent } from "../../../lib/content";
import { getResearchTopics } from "../../../lib/research-topics";
import { withBasePath } from "../../../lib/urls";

type TopicMarkdownModule = {
	default: AstroComponentFactory;
	frontmatter?: {
		title?: string;
		description?: string;
		lead?: string;
	};
};

const markdownModules = import.meta.glob(
	"../../../content/research-topics/*.{md,mdx}",
) as Record<string, () => Promise<TopicMarkdownModule>>;
const allTopics = getResearchTopics("en");

export function getStaticPaths() {
	return getResearchTopics("en").map((topic) => ({
		params: { topicSlug: topic.slug },
		props: { topic },
	}));
}

const { topic } = Astro.props;
const topicIndex = allTopics.findIndex((entry) => entry.slug === topic.slug);
const content = await loadLocalizedContent({
	locale: "en",
	basePath: `../../../content/research-topics/${topic.slug}`,
	markdownModules,
});
const previousTopic = topicIndex > 0 ? allTopics[topicIndex - 1] : undefined;
const nextTopic =
	topicIndex >= 0 && topicIndex < allTopics.length - 1
		? allTopics[topicIndex + 1]
		: undefined;
const relatedTopics = allTopics
	.filter((entry) => entry.slug !== topic.slug)
	.slice(0, 8);
const articleTitle = content.frontmatter?.title ?? topic.title;
const articleDescription = content.frontmatter?.description ?? topic.summary;
const sharePath = withBasePath(
	topic.detailPathEn ?? `/en/research-topics/${topic.slug}`,
) ?? `/en/research-topics/${topic.slug}`;
const shareUrl = new URL(
	sharePath,
	Astro.site ?? new URL("https://hapislab.org"),
).toString();
---

<ResearchTopicArticle
	topic={topic}
	title={articleTitle}
	description={articleDescription}
	currentPath={`/en/research-topics/${topic.slug}`}
	locale="en"
	languageSwitchHref={`/research-topics/${topic.slug}`}
	ContentComponent={content.ContentComponent}
	htmlContent={content.htmlContent}
	fallbackNotice={content.isFallback
		? "This page is not yet available in English. 日本語版の内容を表示しています。"
		: undefined}
	previousTopic={previousTopic}
	nextTopic={nextTopic}
	relatedTopics={relatedTopics}
/>
