---
import { getPublicationCitationDisplay } from "../lib/publication-citation";
import type { Publication } from "../lib/site-data";

interface Props {
	publication: Publication;
	locale?: "ja" | "en";
	className?: string;
	linkClassName?: string;
	fallbackTag?: "div" | "span";
}

const {
	publication,
	locale = "ja",
	className,
	linkClassName,
	fallbackTag = "span",
} = Astro.props;

const citation = getPublicationCitationDisplay(publication, locale);
const CitationTag = publication.href ? "a" : fallbackTag;
const isArticle = publication.type === "article";
const japaneseVenueParts = (
	isArticle
		? [citation.venueDetails, citation.year, citation.doiText]
		: [
				citation.year,
				citation.venueDetails,
				citation.eventDateText,
				citation.locationText,
				citation.doiText,
			]
).filter(Boolean);
const englishVenueParts = (
	isArticle
		? [citation.venueDetails, citation.year]
		: [
				citation.year,
				citation.venueDetails,
				citation.eventDateText,
				citation.locationText,
			]
).filter(Boolean);
---

<CitationTag
	href={publication.href || undefined}
	target={publication.href ? "_blank" : undefined}
	rel={publication.href ? "noopener noreferrer" : undefined}
	class:list={[className, publication.href && linkClassName]}
>
	{
		citation.authorsText && (
			<span class="citation-authors">{citation.authorsText}</span>
		)
	}
	<span class="citation-title">{citation.titleText}</span>
	<span class="citation-venue">
		{
			citation.japaneseStyle ? (
				<>
					{citation.venueName && (
						<span class="venue-name--plain">
							{citation.venueName}
						</span>
					)}
					{japaneseVenueParts.length > 0 &&
						`${citation.venueName ? ". " : ""}${japaneseVenueParts.join(". ")}`}
				</>
			) : (
				<>
					{citation.isProceedings && citation.venueName && (
						<span>in </span>
					)}
					{citation.venueName && (
						<em class="venue-name">{citation.venueName}</em>
					)}
					{englishVenueParts.length > 0 && (
						<span>{`${citation.venueName ? ", " : ""}${englishVenueParts.join(", ")}`}</span>
					)}
					{citation.doiText && ` (${citation.doiText})`}
				</>
			)
		}
		{
			publication.note && (
				<span class="citation-note"> [{publication.note}]</span>
			)
		}
		{
			citation.languageNote && (
				<span class="citation-note"> {citation.languageNote}</span>
			)
		}
	</span>
</CitationTag>

<style>
	.publication-citation {
		display: block;
		font-size: 0.95rem;
		line-height: 1.6;
		color: var(--text, #232323);
		text-decoration: none;
	}

	.publication-ref {
		overflow-wrap: anywhere;
		word-break: normal;
	}

	.publication-citation--link,
	.publication-ref--link {
		color: var(--accent, #0d7288);
	}

	.publication-citation--link:hover,
	.publication-ref--link:hover {
		text-decoration: underline;
	}

	.citation-authors {
		margin-right: 0.35rem;
	}

	.citation-title {
		font-weight: 500;
		margin-right: 0.35rem;
	}

	.citation-authors,
	.citation-title,
	.citation-venue {
		display: inline;
	}

	.venue-name {
		font-style: italic;
	}

	.venue-name--plain {
		font-style: normal;
	}

	.citation-note {
		color: var(--text-subtle, #666);
		font-size: 0.9em;
	}
</style>
