---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import { siteMeta } from "../data/site";
import { englishSiteMeta } from "../data/site-en";
import { resolveAssetObject } from "../lib/public-assets";
import { withBase, withBasePath } from "../lib/urls";
import {
	getHomeResearchTopics,
	getResearchTopics,
} from "../lib/research-topics";
import type { ResearchTopicListItem } from "../lib/research-topics";

interface Props {
	locale?: "ja" | "en";
}

interface HomeProject {
	title: string;
	href: string;
	description?: string;
	image?: string;
	imageAlt?: string;
}

const { locale = "ja" } = Astro.props;

const isEnglish = locale === "en";
const meta = isEnglish ? englishSiteMeta : siteMeta;
const currentPath = isEnglish ? "/en/" : "/";
const latestTopics = getResearchTopics().slice(0, 3);

const newsModules = import.meta.glob("../content/top/news/*.md", {
	eager: true,
});

function isEnglishNewsModule(path: string): boolean {
	return path.endsWith(".en.md");
}

const newsItemsRaw = Object.entries(newsModules)
	.filter(([path]) =>
		isEnglish ? isEnglishNewsModule(path) : !isEnglishNewsModule(path),
	)
	.map(([, mod]: [string, any]) => ({
		Content: mod.Content,
		frontmatter: mod.frontmatter,
	}));

const today = new Date().toISOString().split("T")[0];

const visibleNewsItems = newsItemsRaw
	.filter(({ frontmatter }) => {
		if (!frontmatter.expireDate) return true;
		return frontmatter.expireDate >= today;
	})
	.sort((a, b) =>
		(b.frontmatter.date || "").localeCompare(a.frontmatter.date || ""),
	)
	.slice(0, 5);

const homeContentModules = import.meta.glob("../content/home/*.json", {
	import: "default",
});

const projectsPath = isEnglish
	? "../content/top/projects.en.json"
	: "../content/top/projects.json";
const projectsLoader = homeContentModules[projectsPath];
const projectItems = projectsLoader
	? (((await projectsLoader()) as HomeProject[]) ?? [])
	: [];
const visibleProjectItems = projectItems.filter(
	(project) =>
		project.title.trim().length > 0 && project.href.trim().length > 0,
);

const topicCarouselItems = getHomeResearchTopics();
const visibleTopicCarouselItems = topicCarouselItems.filter((item) => {
	const href = isEnglish
		? item.detailPathEn || item.detailPath
		: item.detailPath;
	return (
		item.title.trim().length > 0 &&
		typeof href === "string" &&
		href.length > 0
	);
});
const topicCarouselEntries = visibleTopicCarouselItems.map((item) => ({
	item,
	imageSrc: item.image,
}));
const projectEntries = visibleProjectItems.map((project) => ({
	project,
	imageSrc: resolveAssetObject(project.image),
}));

const copy = isEnglish
	? {
			affiliation: "The University of Tokyo",
			title: "Shinoda & Makino Lab",
			description:
				"We aim for breakthroughs in real-world informatics by introducing new physical effects and structures into information systems. The current targets include sensing technologies of humans, their environments, and the interactions among them, as well as actuation technologies through the five senses, especially the sense of touch. Our research activities encompass basic theories, hardware and software development, and social implementation, such as the commercialization of our research.",
			overviewHeading: "Haptics & Applied Physics in Synthesis",
			newsHeading: "News",
			affiliationsHeading: "Laboratory affiliations",
			projectsHeading: "Related projects",
			latestHeading: "Latest articles",
			carouselLabel: "Featured research themes",
			articleMeta: (topic: ResearchTopicListItem) => topic.date ?? "",
			articleLinkLabel: "Read more",
			logoAlt: "Shinoda & Makino Lab logo",
		}
	: {
			affiliation: "東京大学",
			title: "篠田・牧野研究室",
			description:
				"システムの中に新しい物理現象や物理的構造を導入することで，従来の壁を越える実世界情報環境を実現します．特に人間，環境，その相互作用のセンシングや，五感，特に触覚に働きかけて人間を支援する技術について，ハードウエアレベルからの提案を行っています．斬新な発想に基づく基礎的・普遍的成果を目指すとともに，それらが人々の問題を解決し，実用技術として幅広く活用されるまでのプロセスも研究のテーマに含まれます．",
			overviewHeading: "Haptics & Applied Physics in Synthesis",
			newsHeading: "News",
			affiliationsHeading: "研究室の所属",
			projectsHeading: "関連プロジェクト",
			latestHeading: "最新記事一覧",
			carouselLabel: "研究テーマ一覧",
			articleMeta: (topic: ResearchTopicListItem) =>
				topic.date?.replace(/-/g, "/") ?? "",
			articleLinkLabel: "詳細を見る",
			logoAlt: "篠田・牧野研究室のロゴ",
		};
---

<Layout
	title={copy.title}
	description={copy.description}
	currentPath={currentPath}
	locale={locale}
>
	{
		visibleTopicCarouselItems.length > 0 && (
			<section
				class="home-page-container home-topic-carousel home-topic-carousel-section"
				data-topic-carousel
				role="region"
				aria-label={copy.carouselLabel}
			>
				<div
					class="home-topic-carousel__viewport"
					data-carousel-viewport
				>
					<button
						class="carousel-nav carousel-nav--prev"
						id="carousel-prev"
						aria-label="Previous"
					>
						<span class="carousel-nav__icon">‹</span>
					</button>

					<div class="home-topic-carousel__track" data-carousel-track>
						{topicCarouselEntries.map(
							({ item, imageSrc }, index) => (
								<article class="home-topic-carousel__item">
									<a
										class="home-topic-carousel__link"
										href={withBasePath(
											isEnglish
												? item.detailPathEn ||
														item.detailPath
												: item.detailPath,
										)}
										draggable="false"
									>
										<Image
											src={imageSrc}
											alt={
												item.imageAlt ??
												(isEnglish
													? item.titleEn || item.title
													: item.title)
											}
											class="home-topic-carousel__image"
											draggable="false"
											width={200}
											height={150}
											loading={
												index < 3 ? "eager" : "lazy"
											}
										/>
										<h3 class="home-topic-carousel__title">
											{isEnglish
												? item.titleEn || item.title
												: item.title}
										</h3>
									</a>
								</article>
							),
						)}
						{topicCarouselEntries.map(({ item, imageSrc }) => (
							<article
								class="home-topic-carousel__item"
								aria-hidden="true"
							>
								<a
									class="home-topic-carousel__link"
									href={withBasePath(
										isEnglish
											? item.detailPathEn ||
													item.detailPath
											: item.detailPath,
									)}
									draggable="false"
								>
									<Image
										src={imageSrc}
										alt={
											item.imageAlt ??
											(isEnglish
												? item.titleEn || item.title
												: item.title)
										}
										class="home-topic-carousel__image"
										draggable="false"
										width={200}
										height={150}
										loading="lazy"
									/>
									<h3 class="home-topic-carousel__title">
										{isEnglish
											? item.titleEn || item.title
											: item.title}
									</h3>
								</a>
							</article>
						))}
					</div>

					<button
						class="carousel-nav carousel-nav--next"
						id="carousel-next"
						aria-label="Next"
					>
						<span class="carousel-nav__icon">›</span>
					</button>
				</div>
			</section>
		)
	}

	<div class="home-page-container">
		<section class="content-section home-section">
			<div class="section-heading section-heading--legacy page-hero">
				<h1>{copy.overviewHeading}</h1>
			</div>

			<div class="home-section__content">
				<div class="home-intro">
					<div class="home-intro__branding">
						<div class="home-overview__body">
							<h4>{copy.affiliation}</h4>
							<h3>{copy.title}</h3>
						</div>
					</div>

					<div class="home-overview__description">
						<p>{copy.description}</p>
					</div>
				</div>

				<div>
					<div
						class="section-heading home-affiliations-block__heading"
					>
						<h4>{copy.affiliationsHeading}</h4>
					</div>

					<ul class="legacy-bullet-list">
						{
							meta.affiliations.map((affiliation) => (
								<li>{affiliation}</li>
							))
						}
					</ul>
				</div>
			</div>
		</section>

		{
			visibleProjectItems.length > 0 && (
				<section class="content-section home-section">
					<div class="section-heading section-heading--legacy page-hero">
						<h1>{copy.projectsHeading}</h1>
					</div>

					<div class="home-section__content">
						<div class="home-projects-list">
							{projectEntries.map(({ project, imageSrc }) => (
								<article class="surface home-project-card">
									<a
										class="home-project-card__link"
										href={withBase(project.href)}
									>
										{imageSrc && (
											<Image
												src={imageSrc}
												alt={
													project.imageAlt ??
													project.title
												}
												class="home-project-card__image"
												width={400}
												height={225}
											/>
										)}
										{!imageSrc && (
											<div
												class="home-project-card__image home-project-card__image--placeholder"
												aria-hidden="true"
											/>
										)}
										<div class="home-project-card__body">
											<h3>{project.title}</h3>
											{project.description && (
												<p>{project.description}</p>
											)}
										</div>
									</a>
								</article>
							))}
						</div>
					</div>
				</section>
			)
		}

		{
			visibleNewsItems.length > 0 && (
				<section class="content-section home-section">
					<div class="section-heading section-heading--legacy page-hero">
						<h1>{copy.newsHeading}</h1>
					</div>

					<div class="home-section__content">
						<div class="home-news-list">
							{visibleNewsItems.map(
								({ Content, frontmatter }) => (
									<article class="surface home-news-card">
										<div class="home-news-card__date">
											{frontmatter.date && (
												<time
													datetime={frontmatter.date}
												>
													{frontmatter.date.replace(
														/-/g,
														"/",
													)}
												</time>
											)}
										</div>
										<div class="home-news-card__content">
											<Content />
										</div>
									</article>
								),
							)}
						</div>
					</div>
				</section>
			)
		}

		<section class="content-section home-section home-latest">
			<div class="section-heading section-heading--legacy page-hero">
				<h1>{copy.latestHeading}</h1>
			</div>

			<div class="home-section__content">
				<div class="home-news__grid">
					{
						latestTopics.map((topic, index) => (
							<article class="news-card">
								<a
									class="news-card__link"
									href={withBasePath(
										isEnglish
											? topic.detailPathEn
											: topic.detailPath,
									)}
								>
									<div
										class:list={[
											"news-card__visual",
											`visual-theme-${((index + 1) % 5) + 1}`,
										]}
									>
										{topic.image && (
											<Image
												src={topic.image}
												alt={
													topic.imageAlt ??
													(isEnglish
														? topic.titleEn ||
															topic.title
														: topic.title)
												}
												class="news-card__image"
												width={400}
												height={300}
											/>
										)}
									</div>
									<h3>
										{isEnglish
											? topic.titleEn || topic.title
											: topic.title}
									</h3>
									<p class="news-card__date">
										◷ {copy.articleMeta(topic)}
									</p>
								</a>
							</article>
						))
					}
				</div>
			</div>
		</section>
	</div>
</Layout>

<style>
	.carousel-nav {
		position: absolute;
		top: 50%;
		transform: translateY(-50%);
		width: 3rem;
		height: 3rem;
		background: rgba(255, 255, 255, 0.8);
		border: 1px solid var(--border);
		color: var(--primary);
		font-size: 2rem;
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		z-index: 10;
		opacity: 0;
		transition:
			opacity 0.3s ease,
			background 0.3s ease;
		padding-bottom: 0.3rem;
		user-select: none;
	}

	.home-topic-carousel__viewport:hover .carousel-nav {
		opacity: 1;
	}

	.carousel-nav:hover {
		background: #fff;
	}

	.carousel-nav--prev {
		left: 0;
	}

	.carousel-nav--next {
		right: 0;
	}

	/* Disable default CSS animation - will be handled by JS */
	[data-carousel-track] {
		animation: none !important;
	}

	/* Use transition for discrete jumps */
	[data-carousel-track].is-jumping {
		transition: transform 0.4s ease-out !important;
	}
</style>

<script>
	function setupCarousel() {
		const track = document.querySelector(
			"[data-carousel-track]",
		) as HTMLElement;
		const viewport = document.querySelector(
			"[data-carousel-viewport]",
		) as HTMLElement;
		const prevBtn = document.getElementById("carousel-prev");
		const nextBtn = document.getElementById("carousel-next");

		if (!track || !viewport || !prevBtn || !nextBtn) return;

		let currentX = 0;
		let lastTimestamp = 0;
		let animationId: number | null = null;

		// States
		let isManual = false;
		let manualDirection = 0; // -1: left, 1: right
		let isLongPress = false;

		const AUTO_SPEED = 0.04; // px per ms (auto scroll)
		const MANUAL_SPEED = 0.8; // px per ms (long press scroll)
		const ITEM_WIDTH = 200 + 20; // width + gap
		const HALF_WIDTH = track.scrollWidth / 2;

		const update = (timestamp: number) => {
			if (!lastTimestamp) lastTimestamp = timestamp;
			const deltaTime = timestamp - lastTimestamp;
			lastTimestamp = timestamp;

			if (isManual) {
				if (isLongPress) {
					// Manual continuous scroll
					currentX += manualDirection * MANUAL_SPEED * deltaTime;
				}
				// If not long press, currentX is updated once by moveByItem
			} else {
				// Auto scroll (always moving left)
				currentX -= AUTO_SPEED * deltaTime;
			}

			// Infinite wrap
			if (currentX > 0) currentX -= HALF_WIDTH;
			if (currentX < -HALF_WIDTH) currentX += HALF_WIDTH;

			// Use setProperty for performance and to ensure we override other styles
			track.style.setProperty(
				"transform",
				`translateX(${currentX}px)`,
				"important",
			);

			animationId = requestAnimationFrame(update);
		};

		const moveByItem = (direction: number) => {
			isManual = true;
			track.classList.add("is-jumping");

			currentX += direction * ITEM_WIDTH;

			// Brief delay to allow transition, then resume auto-scroll
			setTimeout(() => {
				track.classList.remove("is-jumping");
				isManual = false;
			}, 400);
		};

		// Event handlers
		let pressTimer: number | null = null;

		const onStart = (direction: number) => {
			isManual = true;
			isLongPress = false;
			manualDirection = direction;

			pressTimer = window.setTimeout(() => {
				isLongPress = true;
			}, 250);
		};

		const onEnd = (direction: number) => {
			if (pressTimer) clearTimeout(pressTimer);

			if (!isLongPress) {
				moveByItem(direction);
			} else {
				isLongPress = false;
				isManual = false;
			}
			pressTimer = null;
		};

		// Mouse
		prevBtn.addEventListener("mousedown", () => onStart(1));
		nextBtn.addEventListener("mousedown", () => onStart(-1));

		const onGlobalMouseUp = (e: MouseEvent) => {
			if (isManual) {
				const isPrev =
					e.target === prevBtn || prevBtn.contains(e.target as Node);
				const isNext =
					e.target === nextBtn || nextBtn.contains(e.target as Node);

				if (isPrev) onEnd(1);
				else if (isNext) onEnd(-1);
				else {
					if (pressTimer) clearTimeout(pressTimer);
					isLongPress = false;
					isManual = false;
				}
			}
		};

		window.addEventListener("mouseup", onGlobalMouseUp);

		// Stop scroll on hover
		viewport.addEventListener("mouseenter", () => {
			if (!isManual) {
				// We can either pause or just keep it moving.
				// The prompt says "hover pauses", let's keep that logic.
				// For simplicity here, let's keep it moving unless clicking.
			}
		});

		// Touch
		prevBtn.addEventListener("touchstart", (e) => {
			e.preventDefault();
			onStart(1);
		});
		prevBtn.addEventListener("touchend", (e) => {
			e.preventDefault();
			onEnd(1);
		});
		nextBtn.addEventListener("touchstart", (e) => {
			e.preventDefault();
			onStart(-1);
		});
		nextBtn.addEventListener("touchend", (e) => {
			e.preventDefault();
			onEnd(-1);
		});

		animationId = requestAnimationFrame(update);
	}

	setupCarousel();
	document.addEventListener("astro:page-load", setupCarousel);
</script>
